<script>

const deck = document.getElementById('deck');
const slides = document.querySelectorAll('.slide');
const navLinks = document.querySelectorAll('.nav-rail a');
const curPageEl = document.getElementById('curPage');
const curNameEl = document.getElementById('curName');
const heroStage = document.getElementById('heroStage');
const heroImgs = document.querySelectorAll('.hero-img');

// Drive the moving hero from slide data attributes.
// Always set ALL properties (with safe defaults) so values from the
// previous slide can't leak into the current state.
function applyHeroFromSlide(slide) {
  const ds = slide.dataset;
  heroStage.style.setProperty('--hx',  ds.heroX        || '0vw');
  heroStage.style.setProperty('--hy',  ds.heroY        || '0vh');
  heroStage.style.setProperty('--hs',  ds.heroScale    || '1');
  heroStage.style.setProperty('--hr',  ds.heroRotate   || '0deg');
  heroStage.style.setProperty('--hry', ds.heroRotateY  || '0deg');
  heroStage.style.setProperty('--ho',  ds.heroOpacity  || '0');
  if (ds.heroAngle !== undefined) {
    heroImgs.forEach(img => img.classList.toggle('active', img.dataset.angle === ds.heroAngle));
  }
}

// IntersectionObserver — triggers entrance animations + indicator + hero
const io = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('in-view');
      const idx = Array.from(slides).indexOf(entry.target) + 1;
      const name = entry.target.dataset.name || '';
      curPageEl.textContent = String(idx).padStart(2, '0');
      curNameEl.textContent = name;
      navLinks.forEach((a, i) => a.classList.toggle('active', i + 1 === idx));
      applyHeroFromSlide(entry.target);
    }
  });
}, { root: deck, threshold: 0.35 });

slides.forEach(s => io.observe(s));

// Keyboard navigation
window.addEventListener('keydown', (e) => {
  const cur = Array.from(slides).findIndex(s => s.classList.contains('in-view'));
  let next = cur;
  if (['ArrowDown', 'ArrowRight', 'PageDown', ' '].includes(e.key)) {
    e.preventDefault();
    next = Math.min(slides.length - 1, cur + 1);
  } else if (['ArrowUp', 'ArrowLeft', 'PageUp'].includes(e.key)) {
    e.preventDefault();
    next = Math.max(0, cur - 1);
  } else if (e.key === 'Home') { e.preventDefault(); next = 0; }
  else if (e.key === 'End') { e.preventDefault(); next = slides.length - 1; }
  else { return; }
  slides[next].scrollIntoView({ behavior: 'smooth' });
});

// Click on nav rail
navLinks.forEach(a => {
  a.addEventListener('click', (e) => {
    e.preventDefault();
    const idx = parseInt(a.dataset.slide, 10) - 1;
    slides[idx].scrollIntoView({ behavior: 'smooth' });
  });
});

// Initial state
window.addEventListener('load', () => {
  slides[0].classList.add('in-view');
  applyHeroFromSlide(slides[0]);
});

</script>
