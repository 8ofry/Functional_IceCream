<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Functional Ice Cream — Graduation Project, Ain Shams University</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,200..900,0..100;1,9..144,200..900,0..100&family=Manrope:wght@200..800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>

:root {
  --cream:        #F4ECE0;
  --cream-deep:   #EBE0CC;
  --paper:        #FAF6EE;
  --paper-warm:   #F8EFE0;
  --bone:         #E8DFD0;
  --ink:          #1A1614;
  --ink-soft:     #4A4239;
  --ink-mute:     #7A6F62;
  --sage:         #475841;
  --sage-deep:    #2F3A2A;
  --sage-light:   #7E8F76;
  --sage-mist:    #C5CDBC;
  --terracotta:   #B8553A;
  --terra-deep:   #8E3D27;
  --honey:        #C9A063;
  --rose:         #E8C5BD;
  --berry:        #6E2A35;
  --slide-pad:    5vh 6vw;
  --grain-op:     0.04;
}

* { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }

html, body {
  background: var(--cream);
  color: var(--ink);
  font-family: 'Manrope', -apple-system, sans-serif;
  font-weight: 400;
  font-size: 16px;
  line-height: 1.55;
  overflow-x: hidden;
}

.deck {
  scroll-snap-type: y mandatory;
  height: 100vh;
  overflow-y: scroll;
  scroll-behavior: smooth;
}
.deck::-webkit-scrollbar { width: 6px; }
.deck::-webkit-scrollbar-track { background: transparent; }
.deck::-webkit-scrollbar-thumb { background: var(--sage); border-radius: 3px; }

body::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999;
  opacity: var(--grain-op);
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  mix-blend-mode: multiply;
}

/* =================================================
   MOVING HERO — proper CSS 3D rendering using a
   perspective WRAPPER (canonical pattern).
   - .hero-perspective: full-viewport, holds perspective
   - .hero-stage: positioned/scaled/rotated within
   Asymmetric transition: fade-out fast (0.35s) so the
   cone can't bleed into adjacent slides.
   ================================================= */
.hero-perspective {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 4;
  perspective: 1500px;
  perspective-origin: 50% 50%;
}

.hero-stage {
  position: absolute;
  top: 50%;
  left: 50%;
  width: clamp(260px, 26vw, 380px);
  height: 86vh;
  --hx: 0vw;
  --hy: 0vh;
  --hs: 1;
  --hr: 0deg;
  --hry: 0deg;
  --ho: 1;
  transform-style: preserve-3d;
  transform:
    translate(-50%, -50%)
    translate(var(--hx), var(--hy))
    rotateY(var(--hry))
    rotate(var(--hr))
    scale(var(--hs));
  opacity: var(--ho);
  transition:
    transform 1.6s cubic-bezier(0.4, 0, 0.2, 1),
    opacity 0.4s ease;
  filter: drop-shadow(0 30px 50px rgba(26, 22, 20, 0.18));
  will-change: transform, opacity;
  backface-visibility: hidden;
}

.hero-img {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  height: 100%;
  width: auto;
  opacity: 0;
  transition: opacity 0.7s ease;
  user-select: none;
  -webkit-user-drag: none;
  backface-visibility: hidden;
}
.hero-img.active { opacity: 1; }

/* =================================================
   PRODUCT PHOTOS — used inline on slides 4, 6, 9, 17
   Embedded once as CSS backgrounds (not duplicated
   per <img>) for size efficiency.
   ================================================= */
.photo-frame {
  position: relative;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  overflow: hidden;
}
.photo-chocolate { background-image: url('data:image/webp;base64,'); }
.photo-vanilla   { background-image: url('data:image/webp;base64,'); }
.photo-frame::after {
  content: '';
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 0 1px rgba(26, 22, 20, 0.08);
  pointer-events: none;
}

/* =================================================
   SLIDE BASE — fixed flex layout (was broken in v1)
   ================================================= */
.slide {
  scroll-snap-align: start;
  scroll-snap-stop: always;
  height: 100vh;
  width: 100vw;
  padding: var(--slide-pad);
  position: relative;
  overflow: hidden;
}

.slide-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}

.runner {
  position: absolute;
  top: 3vh;
  left: 6vw;
  right: 6vw;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-mute);
  z-index: 5;
}
.runner::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: -10px;
  height: 1px;
  background: var(--ink);
  opacity: 0.15;
}

.foot {
  position: absolute;
  bottom: 3vh;
  left: 6vw;
  right: 6vw;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-mute);
  z-index: 5;
}
.foot::before {
  content: '';
  position: absolute;
  left: 0; right: 0; top: -10px;
  height: 1px;
  background: var(--ink);
  opacity: 0.15;
}

/* =================================================
   TYPOGRAPHY
   ================================================= */
.kicker {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--terracotta);
  font-weight: 500;
}
.body-text {
  font-family: 'Manrope', sans-serif;
  font-size: 15px;
  line-height: 1.65;
  color: var(--ink-soft);
  font-weight: 400;
  max-width: 60ch;
}
.lead {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 32, 'SOFT' 50;
  font-weight: 300;
  font-style: italic;
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.4;
  color: var(--ink);
  max-width: 28ch;
}

/* =================================================
   NAVIGATION
   ================================================= */
.nav-rail {
  position: fixed;
  right: 22px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: 7px;
}
.nav-rail a {
  display: block;
  width: 18px;
  height: 2px;
  background: var(--ink);
  opacity: 0.2;
  transition: all 0.35s ease;
  text-decoration: none;
}
.nav-rail a:hover { opacity: 0.6; width: 26px; }
.nav-rail a.active { opacity: 0.95; width: 32px; background: var(--terracotta); }

.page-indicator {
  position: fixed;
  bottom: 24px;
  left: 24px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-mute);
  z-index: 100;
  background: rgba(244, 236, 224, 0.85);
  backdrop-filter: blur(6px);
  padding: 8px 12px;
  border: 1px solid rgba(26, 22, 20, 0.12);
}
.page-indicator b { color: var(--ink); font-weight: 500; }

/* =================================================
   SLIDE 1 — COVER
   ================================================= */
.cover { background: var(--paper); }
.cover .slide-inner { gap: 0; }
.cover-masthead {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-bottom: 22px;
  border-bottom: 1.5px solid var(--ink);
  margin-bottom: clamp(40px, 5vh, 60px);
  flex-shrink: 0;
}
.cover-masthead .pub {
  font-family: 'Fraunces', serif;
  font-style: italic;
  font-weight: 300;
  font-size: 22px;
  letter-spacing: -0.01em;
}
.cover-masthead .meta {
  display: flex;
  gap: 24px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-mute);
}
.cover-body {
  flex: 1;
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 40px;
  align-items: center;
}
.cover-title {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 144, 'SOFT' 60;
  font-weight: 300;
  font-size: clamp(54px, 7.6vw, 116px);
  line-height: 0.92;
  letter-spacing: -0.035em;
  color: var(--ink);
}
.cover-title em {
  font-style: italic;
  font-variation-settings: 'opsz' 144, 'SOFT' 100;
  color: var(--terracotta);
  font-weight: 300;
}
.cover-foot {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 24px;
  padding-top: 20px;
  border-top: 1px solid var(--ink);
  flex-shrink: 0;
}
.cover-foot .col h4 {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-mute);
  margin-bottom: 10px;
  font-weight: 500;
}
.cover-foot .col p {
  font-family: 'Fraunces', serif;
  font-size: 14px;
  line-height: 1.4;
  color: var(--ink);
}
.cover-foot .col p span {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--ink-mute);
  margin-left: 6px;
  letter-spacing: 0.05em;
}

/* =================================================
   SLIDE 2 — STAT HOOK with curl arrows
   Layout: [cone takes the left ~28vw] | text | stats
   We give the cone its own real estate by adding
   left padding to slide-inner.
   ================================================= */
.stat-hook { background: var(--cream); }
.stat-hook .slide-inner {
  justify-content: center;
  padding-left: 22vw;  /* leaves room for the cone */
}
.stat-hook .grid {
  display: grid;
  grid-template-columns: 0.95fr 1fr;
  gap: 70px;
  align-items: center;
}
.stat-hook .big {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 144, 'SOFT' 30;
  font-weight: 250;
  font-size: clamp(44px, 6vw, 96px);
  line-height: 0.96;
  letter-spacing: -0.03em;
}
.stat-hook .big em {
  font-style: italic;
  color: var(--terracotta);
  font-variation-settings: 'opsz' 144, 'SOFT' 100;
}
.stat-hook .right {
  display: flex;
  flex-direction: column;
  gap: 24px;
  position: relative;
}
.stat-hook .stat-card {
  border-left: 2px solid var(--sage);
  padding: 6px 0 6px 22px;
  position: relative;
  z-index: 2;
  background: var(--cream);
}
.stat-hook .stat-card .num {
  font-family: 'Fraunces', serif;
  font-size: 46px;
  font-weight: 300;
  color: var(--sage-deep);
  line-height: 1;
}
.stat-hook .stat-card .lbl {
  font-family: 'Manrope', sans-serif;
  font-size: 13.5px;
  color: var(--ink-soft);
  margin-top: 6px;
  max-width: 30ch;
  line-height: 1.45;
}

/* Curl arrows — scoped to slide 2 */
.curl-arrows {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  opacity: 0;
  transition: opacity 0.5s ease 0.3s;
}
.slide.in-view .curl-arrows { opacity: 1; }
.curl-arrows path.curl {
  fill: none;
  stroke: var(--terracotta);
  stroke-width: 2;
  stroke-linecap: round;
  stroke-dasharray: 100;
  stroke-dashoffset: 100;
}
.slide.in-view .curl-arrows path.curl {
  animation: drawArrow 1.4s cubic-bezier(0.65, 0, 0.35, 1) forwards;
}
.slide.in-view .curl-arrows .curl-1 { animation-delay: 0.5s; }
.slide.in-view .curl-arrows .curl-2 { animation-delay: 0.75s; }
.slide.in-view .curl-arrows .curl-3 { animation-delay: 1.0s; }
.slide.in-view .curl-arrows .curl-4 { animation-delay: 1.25s; }

@keyframes drawArrow {
  to { stroke-dashoffset: 0; }
}

/* =================================================
   SLIDE 3 — SPLIT
   ================================================= */
.split {
  background: var(--paper);
  padding: 0 !important;
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.split .half {
  padding: var(--slide-pad);
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.split .half.left {
  background: var(--paper-warm);
  border-right: 1px solid var(--ink);
}
.split .half.right {
  background: var(--sage-deep);
  color: var(--paper);
}
.split .half.right .kicker { color: var(--honey); }
.split .half.right h2 { color: var(--paper); }
.split .half.right p { color: rgba(244, 246, 238, 0.78); }
.split h2 {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 144, 'SOFT' 50;
  font-weight: 300;
  font-size: clamp(36px, 4.2vw, 60px);
  line-height: 1.0;
  letter-spacing: -0.025em;
  margin: 18px 0 24px;
}
.split h2 em { font-style: italic; }
.split p {
  font-family: 'Manrope', sans-serif;
  font-size: 15px;
  line-height: 1.65;
  color: var(--ink-soft);
  max-width: 42ch;
}
.split .tag {
  display: inline-block;
  margin-top: 36px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 8px 14px;
  border: 1px solid currentColor;
  border-radius: 100px;
}

/* =================================================
   SLIDE 4 — AIM
   ================================================= */
.aim { background: var(--cream); }
.aim .head { margin-bottom: 50px; flex-shrink: 0; }
.aim h1 {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 144, 'SOFT' 50;
  font-weight: 300;
  font-size: clamp(40px, 4.8vw, 72px);
  line-height: 0.98;
  letter-spacing: -0.025em;
  margin-top: 14px;
  max-width: 22ch;
}
.aim h1 em { font-style: italic; color: var(--terracotta); }
.aim .products {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 36px;
  align-items: center;
}
.aim .prod-card {
  background: var(--paper);
  padding: 36px;
  border: 1px solid rgba(26, 22, 20, 0.08);
  display: flex;
  flex-direction: column;
  gap: 16px;
  height: 100%;
  max-height: 420px;
}
.aim .prod-card .num {
  font-family: 'Fraunces', serif;
  font-style: italic;
  font-weight: 300;
  font-size: 60px;
  color: var(--sage);
  line-height: 0.85;
}
.aim .prod-card h3 {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 144, 'SOFT' 50;
  font-weight: 350;
  font-size: 28px;
  line-height: 1.1;
  letter-spacing: -0.015em;
}
.aim .prod-card p {
  font-family: 'Manrope', sans-serif;
  font-size: 14px;
  line-height: 1.6;
  color: var(--ink-soft);
}
.aim .prod-card .tags {
  margin-top: auto;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.aim .prod-card .tags span {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 5px 10px;
  background: var(--bone);
  color: var(--ink-soft);
}

/* =================================================
   SLIDE 5 — CRITERIA
   ================================================= */
.criteria { background: var(--paper); }
.criteria .head {
  display: flex;
  justify-content: space-between;
  align-items: end;
  margin-bottom: 36px;
  gap: 40px;
  flex-shrink: 0;
}
.criteria h2 {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 144, 'SOFT' 50;
  font-weight: 300;
  font-size: clamp(36px, 4vw, 56px);
  line-height: 0.98;
  letter-spacing: -0.025em;
  max-width: 18ch;
}
.criteria h2 em { font-style: italic; color: var(--terracotta); }
.criteria .head .desc { font-family: 'Fraunces', serif; font-style: italic; font-size: 16px; color: var(--ink-soft); max-width: 32ch; line-height: 1.5; font-weight: 300; }
.criteria .grid {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: 1fr 1fr;
  gap: 0;
  border-top: 1px solid var(--ink);
  border-left: 1px solid var(--ink);
}
.criteria .item {
  border-right: 1px solid var(--ink);
  border-bottom: 1px solid var(--ink);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  position: relative;
  background: var(--paper);
  transition: background 0.3s;
}
.criteria .item:hover { background: var(--cream); }
.criteria .item .ic { width: 32px; height: 32px; color: var(--sage); }
.criteria .item .n {
  position: absolute;
  top: 12px;
  right: 16px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.15em;
  color: var(--ink-mute);
}
.criteria .item h4 {
  font-family: 'Fraunces', serif;
  font-weight: 400;
  font-size: 19px;
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: var(--ink);
}
.criteria .item p {
  font-family: 'Manrope', sans-serif;
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-soft);
}

/* =================================================
   PRODUCT INTROS — slides 6 and 9
   ================================================= */
.product-intro.protein { background: var(--cream-deep); }
.product-intro.probiotic { background: var(--bone); }
.product-intro .slide-inner { justify-content: center; }
.product-intro .grid {
  display: grid;
  grid-template-columns: 1fr 0.9fr;
  gap: 60px;
  align-items: center;
}
.product-intro .left { display: flex; flex-direction: column; gap: 26px; }
.product-intro h1 {
  font-family: 'Fraunces', serif;
  font-variation-settings: 'opsz' 144, 'SOFT' 60;
  font-weight: 300;
  font-size: clamp(54px, 6.6vw, 104px);
  line-height: 0.92;
  letter-spacing: -0.035em;
}
.product-intro h1 em {
  font-style: italic;
  font-variation-settings: 'opsz' 144, 'SOFT' 100;
}
.product-intro .protein h1 em { color: var(--terracotta); }
.product-intro .probiotic h1 em { color: var(--sage); }
.product-intro .lead { max-width: 38ch; font-size: clamp(17px, 1.6vw, 22px); }
.product-intro .stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 22px;
  padding-top: 22px;
  border-top: 1px solid rgba(26, 22, 20, 0.2);
  max-width: 600px;
}
.product-intro .stats .s .v {
  font-family: 'Fraunces', serif;
  font-weight: 350;
  font-size: 32px;
  color: var(--sage-deep);
  line-height: 1;
}
.product-intro .stats .s .l {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9.5px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-mute);
  margin-top: 6px;
}

/* Product card photo (slide 4) — sits at top of card */
.prod-card-photo {
  width: 100%;
  height: 160px;
  margin: -36px -36px 8px -36px;
  width: calc(100% + 72px);
}

/* Product photo block (slides 6 & 9) — replaces label card with real photo */
.product-photo-block {
  position: relative;
  width: 100%;
  height: 65vh;
  max-height: 560px;
  display: flex;
  flex-direction: column;
  box-shadow: 0 30px 60px -20px rgba(26, 22, 20, 0.22);
}
.product-photo-block .photo-frame {
  flex: 1;
  height: auto;
}
.product-photo-block .photo-caption {
  background: var(--paper);
  padding: 18px 22px;
  border-top: 1px solid rgba(26, 22, 20, 0.08);
}
.product-photo-block .photo-caption .stamp {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.22em;
  color: var(--terracotta);
  text-transform: uppercase;
  margin-bottom: 6px;
}
.product-photo-block .photo-caption .cap-name {
  font-family: 'Fraunces', serif;
  font-weight: 400;
  font-size: 17px;
  line-height: 1.25;
  letter-spacing: -0.01em;
}
.product-photo-block .photo-caption .cap-name em { font-style: italic; }

/* Marketing accent photo (slide 17) — small framed image below the pull-quote */
.marketing-photo {
  margin-top: 28px;
  width: 220px;
  height: 280px;
  box-shadow: 0 20px 40px -15px rgba(26, 22, 20, 0.25);
  position: relative;
}
.marketing-photo::before {
  content: '— ON THE LINE';
  position: absolute;
  top: -22px;
  left: 0;
